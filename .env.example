# Telegram bot token (required)
BOT_TOKEN=your_bot_token_here

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cooldown in seconds for (group, user, keyword)
COOLDOWN_SECONDS=30

# SQLite DB path (optional, defaults to ./data/bot.db)
# On Render, this will be stored in the project directory
SQLITE_PATH=./data/bot.db
